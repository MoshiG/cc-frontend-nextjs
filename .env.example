# Backend URL used by Next.js server-side code (route handlers, server components).
# Must be reachable from the Node process running `next dev` / `next start`.
#
# Local dev via SSH tunnel to Contabo:
#   ssh -L 8000:127.0.0.1:8000 goodiel@45.141.22.70
#   INTERNAL_API_URL=http://127.0.0.1:8000
#
# Same-host production (frontend + backend on the same VPS, gateway bound to loopback):
#   INTERNAL_API_URL=http://127.0.0.1:8000
INTERNAL_API_URL=http://127.0.0.1:8000

# Backend URL used by client-side code (browser).
# Leave empty so browser requests go to the same origin and are proxied by Nginx.
# Only set this if the API is on a different host than the frontend.
NEXT_PUBLIC_API_URL=
